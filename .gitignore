*.keras
*.h5
*.pb
saved_model/

# ── Generated plot images ─────────────────────────────────────────────────────
*.png
*.jpg
*.jpeg

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

# ── Jupyter Notebook checkpoints ─────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs & profiling ──────────────────────────────────────────────────────────
logs/
*.log
*.tsv
tensorboard_logs/

# ── Environment files ─────────────────────────────────────────────────────────
.env
.env.local
